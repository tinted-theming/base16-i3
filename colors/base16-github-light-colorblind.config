## Base16 Github Light Colorblind
# Scheme author: Tinted Theming (https://github.com/tinted-theming)
# Template author: Tinted Theming (https://github.com/tinted-theming)
#
# You can use these variables anywhere in the i3 configuration file.

set $base00 #ffffff
set $base01 #f6f8fa
set $base02 #afb8c1
set $base03 #8c959f
set $base04 #6e7781
set $base05 #424a53
set $base06 #32383f
set $base07 #24292f
set $base08 #8a4600
set $base09 #0550ae
set $base0A #bf8700
set $base0B #0a3069
set $base0C #0550ae
set $base0D #8250df
set $base0E #b35900
set $base0F #6f3800
